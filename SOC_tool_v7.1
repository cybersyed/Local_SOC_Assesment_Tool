def apply_ad_filter(*_):
    search = ad_filter_var.get().lower()
    flagged_only = show_flagged_var.get()
    for item in ad_accounts_table.get_children():
        vals = ad_accounts_table.item(item, "values")
        username = vals[0].lower() if vals else ""
        risk = vals[8] if vals else ""
        name_match   = search in username
        flag_match   = (not flagged_only) or (risk != "OK")
        if name_match and flag_match:
            ad_accounts_table.reattach(item, "", tk.END)
        else:
            ad_accounts_table.detach(item)


ad_filter_var.trace_add("write", apply_ad_filter)
show_flagged_var.trace_add("write", apply_ad_filter)

