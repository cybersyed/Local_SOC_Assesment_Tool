def sort_ad_table(col, reverse):
    """Sort the AD accounts table by a column when heading is clicked."""
    data = [(ad_accounts_table.set(child, col), child)
            for child in ad_accounts_table.get_children("")]
    data.sort(reverse=reverse)
    for index, (_, child) in enumerate(data):
        ad_accounts_table.move(child, "", index)
    ad_accounts_table.heading(col, command=lambda: sort_ad_table(col, not reverse))


