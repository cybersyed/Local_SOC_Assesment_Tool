# =========================
# PowerShell helpers
# =========================

def run_ps(command):
    result = subprocess.run(
        ["powershell", "-Command", command],
        capture_output=True,
        text=True
    )
    return result.stdout.strip()


def get_event_count(event_id):
    output = run_ps(
        f"(Get-WinEvent -FilterHashtable @{{LogName='Security'; ID={event_id}}} -MaxEvents 100).Count"
    )
    try:
        return int(output)
    except:
        return 0


# =========================
# Assessment checks
# =========================

def score_control(result, weight):
    return weight if result else 0


def check_privileged_group():
    output = run_ps("Get-ADGroupMember 'Domain Admins' | Select-Object -ExpandProperty SamAccountName")
    members = [m for m in output.splitlines() if m.strip()]
    return len(members) <= 3, members


def check_stale_accounts():
    output = run_ps("""
    $cutoff = (Get-Date).AddDays(-90)
    Get-ADUser -Filter * -Properties LastLogonDate,Enabled |
    Where-Object {$_.Enabled -eq $true -and ($_.LastLogonDate -eq $null -or $_.LastLogonDate -lt $cutoff)} |
    Select-Object -ExpandProperty SamAccountName
    """)
    stale = [x for x in output.splitlines() if x.strip()]
    return len(stale) == 0, stale


def check_logs():
    output = run_ps("Get-WinEvent -LogName Security -MaxEvents 5")
    return bool(output), None


def check_disabled_accounts():
    output = run_ps("""
    $privGroups = @("Domain Admins","Enterprise Admins","Schema Admins","Administrators","Backup Operators")
    foreach ($group in $privGroups) {
        try {
            Get-ADGroupMember $group -Recursive |
            Where-Object {$_.objectClass -eq "user"} |
            ForEach-Object {
                $u = Get-ADUser $_.SamAccountName -Properties Enabled
                if ($u.Enabled -eq $false) { $u.SamAccountName }
            }
        } catch {}
    }
    """)
    disabled = [x for x in output.splitlines() if x.strip()]
    return len(disabled) == 0, disabled


def check_failed_logons():
    count = get_event_count(4625)
    return count > 0, count


def check_event_coverage():
    missing = []
    for eid in REQUIRED_EVENT_IDS:
        if get_event_count(eid) == 0:
            missing.append(eid)
    return len(missing) == 0, missing


def check_audit_policy():
    output = run_ps("auditpol /get /category:*")
    required_terms = ["Logon", "Credential Validation", "User Account Management", "Security Group Management"]
    missing = [term for term in required_terms if term not in output]
    return len(missing) == 0, missing


def detect_bruteforce():
    output = run_ps("""
    Get-WinEvent -FilterHashtable @{LogName='Security'; ID=4625} -MaxEvents 100 |
    ForEach-Object {
        $xml = [xml]$_.ToXml()
        $targetUser = ($xml.Event.EventData.Data | Where-Object {$_.Name -eq 'TargetUserName'}).'#text'
        if ($targetUser) { $targetUser }
    }
    """)
    attempts = {}
    for user in output.splitlines():
        user = user.strip()
        if user and user not in ["-", "SYSTEM"]:
            attempts[user] = attempts.get(user, 0) + 1
    return {u: c for u, c in attempts.items() if c >= 5}


def detect_privileged_group_change():
    count = get_event_count(4728)
    return count > 0, count


# =========================
# AD Accounts query
# =========================

def fetch_ad_accounts():
    """
    Returns a list of dicts, one per AD user, with key fields.
    Pulls: SamAccountName, DisplayName, Enabled, LastLogonDate,
           PasswordLastSet, PasswordNeverExpires, LockedOut, MemberOf (first group).
    """
    ps = """
    Get-ADUser -Filter * -Properties DisplayName,Enabled,LastLogonDate,PasswordLastSet,
        PasswordNeverExpires,LockedOut,MemberOf |
    Select-Object SamAccountName,DisplayName,Enabled,LastLogonDate,PasswordLastSet,
        PasswordNeverExpires,LockedOut,
        @{N='PrimaryGroup';E={
            if ($_.MemberOf) {
                ($_.MemberOf[0] -replace '^CN=([^,]+),.+$','$1')
            } else { 'None' }
        }} |
    ConvertTo-Json -Depth 2
    """
    raw = run_ps(ps)
    if not raw:
        return []
    try:
        data = json.loads(raw)
        # PowerShell may return a single object instead of a list
        if isinstance(data, dict):
            data = [data]
        return data
    except Exception:
        return []


def fmt_date(val):
    """Format a PowerShell date string to a readable form, or return 'Never'."""
    if not val:
        return "Never"
    # PowerShell JSON dates look like "/Date(1234567890000)/" or ISO strings
    if isinstance(val, str):
        if val.startswith("/Date("):
            try:
                ts = int(val[6:-2]) / 1000
                return datetime.fromtimestamp(ts).strftime("%Y-%m-%d")
            except Exception:
                return val
        # Trim time portion for readability
        return val[:10] if len(val) >= 10 else val
    return str(val)


def flag_account(row):
    """Return a short risk flag string based on account properties."""
    flags = []
    enabled = row.get("Enabled", True)
    last_logon = row.get("LastLogonDate")
    pwd_never = row.get("PasswordNeverExpires", False)
    locked = row.get("LockedOut", False)

    if locked:
        flags.append("LOCKED")
    if not enabled:
        flags.append("DISABLED")
    if pwd_never:
        flags.append("PWD-NEVER-EXPIRES")
    if not last_logon:
        flags.append("NEVER-LOGGED-IN")
    else:
        # Stale: no logon in 90 days
        try:
            if isinstance(last_logon, str):
                if last_logon.startswith("/Date("):
                    ts = int(last_logon[6:-2]) / 1000
                    logon_dt = datetime.fromtimestamp(ts)
                else:
                    logon_dt = datetime.fromisoformat(last_logon[:19])
                if (datetime.now() - logon_dt).days > 90:
                    flags.append("STALE")
        except Exception:
            pass

    return ", ".join(flags) if flags else "OK"


def load_ad_accounts_into_table():
    """Called by the Refresh button on the AD Accounts tab."""
    ad_status_label.config(text="Querying Active Directory...", fg=FG_MUTED)
    root.update_idletasks()

    for item in ad_accounts_table.get_children():
        ad_accounts_table.delete(item)

    accounts = fetch_ad_accounts()

    if not accounts:
        ad_status_label.config(
            text="No accounts returned. Ensure this machine has RSAT / AD module and domain connectivity.",
            fg=FG_RED
        )
        return

    total = len(accounts)
    flagged = 0

    for row in accounts:
        sam        = row.get("SamAccountName", "")
        display    = row.get("DisplayName") or ""
        enabled    = "Yes" if row.get("Enabled", False) else "No"
        last_logon = fmt_date(row.get("LastLogonDate"))
        pwd_set    = fmt_date(row.get("PasswordLastSet"))
        pwd_never  = "Yes" if row.get("PasswordNeverExpires", False) else "No"
        locked     = "Yes" if row.get("LockedOut", False) else "No"
        group      = row.get("PrimaryGroup") or "None"
        risk_flag  = flag_account(row)

        tag = "ok"
        if "LOCKED" in risk_flag or "NEVER-LOGGED-IN" in risk_flag:
            tag = "high"
            flagged += 1
        elif "DISABLED" in risk_flag or "STALE" in risk_flag or "PWD-NEVER-EXPIRES" in risk_flag:
            tag = "warn"
            flagged += 1

        ad_accounts_table.insert(
            "", tk.END,
            values=(sam, display, enabled, last_logon, pwd_set, pwd_never, locked, group, risk_flag),
            tags=(tag,)
        )

    ad_status_label.config(
        text=f"Loaded {total} accounts  |  {flagged} flagged for review",
        fg=FG_YELLOW if flagged else FG_MUTED
    )


def on_ad_account_click(event):
    selected = ad_accounts_table.focus()
    if not selected:
